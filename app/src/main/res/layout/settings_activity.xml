<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    tools:context=".SettingsActivity">

    <Switch
        android:id="@+id/prefer_app_folder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@null"
        android:foreground="?android:selectableItemBackground"
        android:minHeight="56dp"
        android:paddingStart="?android:dialogPreferredPadding"
        android:paddingTop="16dp"
        android:paddingEnd="?android:dialogPreferredPadding"
        android:paddingBottom="16dp"
        android:text="@string/settings_prefer_app_folder"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:paddingStart="?android:dialogPreferredPadding"
        android:paddingEnd="?android:dialogPreferredPadding"
        android:text="@string/settings_prefer_app_folder_summary" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="?android:dialogPreferredPadding"
        android:layout_marginEnd="?android:dialogPreferredPadding"
        android:background="?android:attr/listDivider" />

    <Switch
        android:id="@+id/use_custom_folder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@null"
        android:foreground="?android:selectableItemBackground"
        android:minHeight="56dp"
        android:paddingStart="?android:dialogPreferredPadding"
        android:paddingTop="16dp"
        android:paddingEnd="?android:dialogPreferredPadding"
        android:paddingBottom="16dp"
        android:text="@string/settings_use_custom_folder"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:paddingStart="?android:dialogPreferredPadding"
        android:paddingEnd="?android:dialogPreferredPadding"
        android:text="@string/settings_use_custom_folder_summary" />

    <LinearLayout
        android:id="@+id/custom_folder_path_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="56dp"
        android:orientation="vertical"
        android:paddingStart="?android:dialogPreferredPadding"
        android:paddingTop="16dp"
        android:paddingEnd="?android:dialogPreferredPadding"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_custom_folder_path"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/custom_folder_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_custom_folder_not_set"
            android:textColor="?android:textColorSecondary"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>